{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "matnoble-portal",
  "pages_build_output_dir": "docs/.vitepress/dist",
  "r2_buckets": [
    {
      "binding": "DOWNLOADS_BUCKET",
      "bucket_name": "matnoble-assets"
    }
  ],
  "d1_databases": [
    {
      "binding": "PAGE_VIEWS_DB",
      "database_name": "matnoble-page-views",
      "database_id": "7bbb066b-f474-4daf-9248-24f32a0ec454",
      "remote": true
    }
  ]
}
